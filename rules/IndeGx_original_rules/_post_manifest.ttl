@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix kgi: <http://ns.inria.fr/kg/index#> .

<> a mf:Manifest ;
    mf:include (
        <post/equivalences/manifest.ttl>
        <post/inclusion/manifest.ttl>
        <post/redundancy/manifest.ttl>
        <post/vocabularies/_manifest.ttl>
    ) ;
    mf:entries (
        <post/initialization.ttl>
    ) .

<post/initialization.ttl>  a mf:ManifestEntry ;
    kgi:onSuccess (
        [
            mf:action """
            LOAD <https://raw.githubusercontent.com/Wimmics/IndeGx/main/rules/indegx_metadata_description.ttl>
            """
        ]
    ) .
